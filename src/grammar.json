{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "sgf",
  "rules": {
    "collection": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "game_tree"
      }
    },
    "game_tree": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "SYMBOL",
          "name": "sequence"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "game_tree"
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "sequence": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "node"
      }
    },
    "node": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": ";"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "property"
          }
        }
      ]
    },
    "property": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "property_identifier"
          }
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "FIELD",
            "name": "value",
            "content": {
              "type": "SYMBOL",
              "name": "property_value"
            }
          }
        }
      ]
    },
    "property_identifier": {
      "type": "PATTERN",
      "value": "[A-Za-z]+"
    },
    "property_value": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "value_content"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "value_content": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "REPEAT1",
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "[^\\\\\\]]+"
            },
            {
              "type": "PATTERN",
              "value": "\\\\[\\s\\S]"
            }
          ]
        }
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[\\s\\uFEFF\\u2060\\u200B]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}